---
import BaseLayout from './BaseLayout.astro';
import ArticleList from '../components/ArticleList.astro'; // Import your component

// Get all posts to pass to the sidebar
const allPosts = Object.values(import.meta.glob('../pages/blog/posts/*.md', { eager: true }));

const { frontmatter } = Astro.props;

const formatDate = (date: string) => 
  new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
---

<BaseLayout >
  <div class="page-wrapper">
    <aside class="sidebar" style="width: 300px; height: 100vh; position: sticky; top: 0;">
      <div class="sidebar-sticky">
        <h2 class="sidebar-title">All posts</h2>
        <ArticleList posts={allPosts} />
      </div>
    </aside>

    <article class="post-container">
      <header class="post-header">
        <h1 class="post-title">{frontmatter.title}</h1>
        <div class="post-meta">
          <span>By {frontmatter.author}</span>
          <span class="divider">•</span>
          <time>{formatDate(frontmatter.pubDate)}</time>
        </div>

        <!-- {frontmatter.image && (
          <img src={frontmatter.image.url} alt={frontmatter.image.alt} class="hero-img" />
        )} -->
      </header>

      <section class="post-content">
        <slot />
      </section>

      <footer class="post-footer">
        <div class="tags-container">
          {frontmatter.tags?.map((tag: string) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="tag-link">#{tag}</a>
          ))}
        </div>
      </footer>
    </article>
  </div>
</BaseLayout>

<style>


    .tag-link {
    display: inline-block;
    background: rgba(59, 130, 246, 0.1); 
    color: #60a5fa; 
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: lowercase;
    text-decoration: none;
    border: 1px solid rgba(59, 130, 246, 0.2);
    transition: all 0.2s ease;
  }

  .tag-link:hover {
    background: #3b82f6;
    color: white;
    border-color: #3b82f6;
    transform: translateY(-1px);
  }
  
  .page-wrapper {
    display: grid;
    grid-template-columns: 350px 1fr; 
    gap: 4rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }


  .sidebar {
    border-right: 1px solid rgba(0,0,0,0.1);
    padding-right: 2rem;
  }

  .sidebar-sticky {
    position: sticky;
    top: 2rem; 
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    padding-bottom: 1rem;
  }

  .sidebar-title {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    color: #888;
  }


  .post-container {
    max-width: 800px; 
    margin: 0; 
  }

  .hero-img {
    width: 100%;
    border-radius: 8px;
    margin: 2rem 0;
  }

  .post-content {
    font-size: 1.2rem;
    line-height: 1.8;
  }


  @media (max-width: 1100px) {
    .page-wrapper {
      grid-template-columns: 1fr; 
      gap: 2rem;
    }
    .sidebar {
      border-right: none;
      border-bottom: 1px solid #eee;
      padding-right: 0;
      padding-bottom: 2rem;
    }
    .sidebar-sticky {
      position: static;
      max-height: none;
    }
  }

  .sidebar :global(.article-card) {
    padding: 1rem;
    font-size: 0.9rem;
    background: transparent;
  }
</style>